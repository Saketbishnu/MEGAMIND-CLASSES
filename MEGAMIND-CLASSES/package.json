{
  "name": "megamind-classes",
  "version": "0.1.0",
  "private": true,
  "description": "Production MERN EdTech platform scaffold for MEGAMIND CLASSES.",
  "workspaces": [
    "frontend",
    "admin",
    "backend"
  ],
  "scripts": {
    "dev": "concurrently -n frontend,admin,backend -c cyan,magenta,green \"npm run dev --workspace frontend\" \"npm run dev --workspace admin\" \"npm run dev --workspace backend\"",
    "dev:frontend": "npm run dev --workspace frontend",
    "dev:admin": "npm run dev --workspace admin",
    "dev:backend": "npm run dev --workspace backend",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "format": "prettier --write \"**/*.{js,jsx,json,md,css}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,json,md,css}\"",
    "test": "npm run test --workspaces --if-present"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "prettier": "^3.4.2"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
